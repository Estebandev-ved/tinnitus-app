rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Daily logs: owner only
    match /dailyLogs/{userId}/logs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Progress notes: owner only
    match /progressNotes/{userId}/notes/{noteId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Medical profiles: owner only
    match /medicalProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Audiometry: owner only
    match /audiometry/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Chat history: owner only
    match /chatHistory/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Streaks: owner only
    match /streaks/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Community posts: any authenticated user can read, owner can write
    match /communityPosts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    // Sound library: any authenticated user can read, admins can write
    match /soundLibrary/{soundId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Caregiver links: only the patient or caregiver can access
    match /caregiverLinks/{linkId} {
      allow read, write: if request.auth != null &&
        (resource.data.patientId == request.auth.uid || resource.data.caregiverId == request.auth.uid);
      allow create: if request.auth != null;
    }

    // Download events: anyone can write (anonymous tracking), only admin can read
    // Security: unauthenticated write only allows specific fields (rate limiting via Firebase quotas)
    match /download_events/{eventId} {
      allow write: if true; // Anonymous tracking - only timestamp/platform/source written by client
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/data).data.role == 'admin'
        || (request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Admin config: only admin UID can access
    match /admin_config/{doc} {
      allow read, write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
